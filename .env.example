# Copy this file to .env and fill in your Supabase project values.
# Never commit .env to version control.

# Found in: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Found in: Supabase Dashboard → Project Settings → API → service_role (secret)
# This key bypasses Row Level Security — keep it server-side only.
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Optional: change the port the server listens on (default 3000)
PORT=3000
